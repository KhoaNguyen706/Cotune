# Keeps the build context small and the cache stable: anything listed here
# never reaches the Docker daemon, so changing it can't invalidate layers.
target/
.git/
.github/
.claude/
.mvn/
mvnw
mvnw.cmd
*.md
.gitignore
docker-compose.yml
# Secrets must never enter a build context — layers are cached and shipped.
.env
# The image builds these itself (npm ci / vite build).
frontend/node_modules/
frontend/dist/
