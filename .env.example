# Copy to `.env` (gitignored) and fill in. Docker Compose reads .env
# automatically; for host-run dev, export these in your shell instead.

# --- Supabase (get the password from Supabase dashboard > Database) ---
# Used by the `supabase` Spring profile (host run):
#   SPRING_PROFILES_ACTIVE=supabase SUPABASE_DB_PASSWORD=... ./mvnw spring-boot:run
SUPABASE_DB_PASSWORD=

# To point the DOCKERIZED app at Supabase instead of the local postgres
# container, uncomment these three (they override the compose defaults):
# SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-ca-central-1.pooler.supabase.com:5432/postgres?sslmode=require
# SPRING_DATASOURCE_USERNAME=postgres.ojnocvbtammmpllnwdre
# SPRING_DATASOURCE_PASSWORD=<your supabase db password>

# --- JWT signing key (optional locally; REQUIRED in real deployments) ---
# JWT_SECRET=<base64, >= 32 bytes: openssl rand -base64 32>

# --- Host port for the dockerized app (default 8080) ---
# COTUNE_PORT=8081
