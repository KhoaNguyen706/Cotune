# Copy to `.env` (gitignored) and fill in. Docker Compose reads .env
# automatically; for host-run dev, export these in your shell instead.

# --- Supabase (get the password from Supabase dashboard > Database) ---
# Used by the `supabase` Spring profile (host run):
#   SPRING_PROFILES_ACTIVE=supabase SUPABASE_DB_PASSWORD=... ./mvnw spring-boot:run
SUPABASE_DB_PASSWORD=

# To point the DOCKERIZED app at Supabase instead of the local postgres
# container, uncomment these three (they override the compose defaults):
# SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-ca-central-1.pooler.supabase.com:5432/postgres?sslmode=require
# SPRING_DATASOURCE_USERNAME=postgres.ojnocvbtammmpllnwdre
# SPRING_DATASOURCE_PASSWORD=<your supabase db password>

# --- JWT signing key (optional locally; REQUIRED in real deployments) ---
# Locally, application.yml's dev fallback applies. The `prod` profile has NO
# fallback, so a real deployment that forgets this refuses to boot — by design.
# JWT_SECRET=<base64, >= 32 bytes: openssl rand -base64 32>

# --- Host port for the dockerized app (default 8080) ---
# COTUNE_PORT=8081

# --- Audio storage (only needed with STORAGE_BACKEND=supabase) -------------
# Locally you want the default (STORAGE_BACKEND=local): bytes go to the disk /
# the compose volume, and none of the below is read.
#
# Any PLATFORM deploy needs `supabase`, because a container filesystem there is
# ephemeral — on Heroku the dyno is recycled at least daily and every uploaded
# sample goes with it. The `prod` profile switches this on for you.
#
# SUPABASE_URL: dashboard > Settings > API > Project URL (https://xxxx.supabase.co)
# SUPABASE_SERVICE_KEY: same page > `service_role` key. NOT the anon key — the
#   anon key is RLS-limited and cannot write to a private bucket. This one is a
#   root credential: never commit it, never expose it to the frontend.
# The bucket is created automatically on first boot if it doesn't exist.
# STORAGE_BACKEND=supabase
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_BUCKET=cotune-audio

# --- Redis relay (only needed when running MORE THAN ONE app instance) -----
# REALTIME_RELAY=redis
#
# Compose talks to the redis service by host/port (no auth on a private network):
# REDIS_HOST=redis
#
# A MANAGED Redis hands you one URL with a password (and usually TLS), which
# host/port cannot express. Set it under Spring's own name — Boot binds
# SPRING_DATA_REDIS_URL -> spring.data.redis.url natively, and leaving it unset
# is what makes host/port apply. (Do NOT add an empty `url:` to application.yml;
# Boot parses "" and refuses to start.)
# SPRING_DATA_REDIS_URL=rediss://:password@host:6379
